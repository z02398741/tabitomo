# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LINE Login (OAuth)
LINE_LOGIN_CHANNEL_ID=your-line-login-channel-id
LINE_LOGIN_CHANNEL_SECRET=your-line-login-channel-secret

# LINE Messaging API (Bot)
LINE_MESSAGING_CHANNEL_SECRET=your-line-messaging-channel-secret
LINE_MESSAGING_ACCESS_TOKEN=your-line-messaging-access-token

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# NextAuth
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=your-random-secret-string

# AI Providers
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=                      # optional, currently disabled

# Cron (random secret string you define)
CRON_SECRET=your-cron-secret
